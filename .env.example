# ============================================================
# AmniX-Finance — Environment Variables
# ⚠️  SECURITY: كل قيمة CHANGE_ME يجب تغييرها قبل الاستخدام
# المرجع الوحيد للـ ports والـ config
# ============================================================

# ── Ingestion Service ─────────────────────────────────────
GRPC_PORT=8090
HTTP_PORT=9091

# ── Processing Service ────────────────────────────────────
PROCESSING_GRPC_PORT=50051
PROCESSING_HTTP_PORT=9093
PROCESSING_ADDR=processing:50051

# ── Redpanda ──────────────────────────────────────────────
# داخل Docker network
REDPANDA_BROKERS=redpanda:9092
# من خارج Docker (local machine)
REDPANDA_BROKERS_EXTERNAL=localhost:19092
KAFKA_GROUP_ID=processing-consumer
KAFKA_TOPIC=market-events

# ── Schema Registry ───────────────────────────────────────
# Redpanda عنده Schema Registry مدمج
# داخل Docker network
SCHEMA_REGISTRY_URL=http://redpanda:8081
# من خارج Docker
SCHEMA_REGISTRY_URL_EXTERNAL=http://localhost:18081

# ── OpenTelemetry ─────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

# ── ClickHouse (Hot Store) ────────────────────────────────
CLICKHOUSE_HOST=clickhouse
# داخل Docker network: 9000 | من خارج Docker: 9100
CLICKHOUSE_PORT=9000
CLICKHOUSE_HOST_PORT=9100
CLICKHOUSE_DB=events
CLICKHOUSE_USER=platform
CLICKHOUSE_PASSWORD=CHANGE_ME
CLICKHOUSE_TLS=false

# ── Postgres (Warm Store) ─────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
# CRITICAL: Must be set in production. Empty in dev when using pgbouncer with sslmode=disable
POSTGRES_SSL_MODE=require
POSTGRES_MAX_OPEN_CONNS=20
POSTGRES_MAX_IDLE_CONNS=5

# للـ Goose CLI و Makefile
POSTGRES_DSN=postgres://platform:CHANGE_ME@localhost:5432/platform?sslmode=disable
GOOSE_MIGRATION_DIR=./services/ingestion/internal/postgres/migrations

# ── Redis (Hot Cache) ────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=CHANGE_ME

# ── MinIO / S3 (Cold Store) ───────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_USE_SSL=false
MINIO_BUCKET_PARQUET=parquet-archive
MINIO_BUCKET_COLD=cold-data
MINIO_BUCKET_TIERED=redpanda-tiered
MINIO_PREFIX=events
