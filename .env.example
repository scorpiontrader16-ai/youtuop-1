# ─── أضف في .env.example الموجود عندك ───────────────────

# Schema Registry
SCHEMA_REGISTRY_URL=http://localhost:8081

# MinIO (S3 Cold Storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_BUCKET_COLD=cold-data
MINIO_BUCKET_PARQUET=parquet-archive
MINIO_BUCKET_TIERED=redpanda-tiered

# ClickHouse — الخطوة 2 (جاهز مسبقاً)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=events
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Postgres Migrations — الخطوة 3 (جاهز مسبقاً)
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5432/events?sslmode=disable
GOOSE_MIGRATION_DIR=./migrations/postgres
