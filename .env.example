# ─────────────────────────────────────────────────────────────────────────────
# Platform — Environment Variables
# Copy to .env and fill in values before running `make dev`
# NEVER commit .env to git
#
# NOTE: docker-compose.yml injects the correct values per service.
#       These defaults match what each service reads via os.Getenv / std::env::var.
# ─────────────────────────────────────────────────────────────────────────────

# ── Redpanda ──────────────────────────────────────────────────────────────────
REDPANDA_BROKERS=redpanda:9092
KAFKA_GROUP_ID=processing-consumer
KAFKA_TOPIC=market-events

# ── Go Ingestion Service ──────────────────────────────────────────────────────
# Read by loadConfig() in services/ingestion/main.go
GRPC_PORT=8080
HTTP_PORT=9090
PROCESSING_ADDR=processing:50051

# ── Rust Processing Service ───────────────────────────────────────────────────
# Read by Config::from_env() in services/processing/src/main.rs
# GRPC_PORT and HTTP_PORT are reused per-service via docker-compose env injection
METRICS_PORT=9090

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
LOG_LEVEL=info

# ── GitHub (CI only — do not fill locally) ────────────────────────────────────
# AWS_OIDC_ROLE_ARN=
# AWS_OIDC_ROLE_ARN_STAGING=
# AWS_OIDC_ROLE_ARN_PRODUCTION=
# TF_STATE_BUCKET=
# TF_LOCK_TABLE=
# GITOPS_TOKEN=
# INFRACOST_API_KEY=
